@startuml
skinparam rectangleRoundCorner 10
skinparam rectangleBorderColor #444
skinparam packageStyle frame

rectangle "Warstwa prezentacji (Frontend)" as presentation #E0F7FA {
    rectangle "React SPA (Vite + TypeScript)" as react
    rectangle "shadcn/ui + Tailwind CSS" as ui
    rectangle "React Router" as routing
}

rectangle "Warstwa API (komunikacja)" as api_layer #FFF9C4 {
    rectangle "REST API (HTTP/JSON)" as rest
    rectangle "Vite Proxy (/api -> backend)" as proxy
}

rectangle "Warstwa logiki biznesowej (Backend)" as business #C8E6C9 {
    rectangle "Kontrolery (TaskController, UserController)" as controllers
    rectangle "Serwisy (TaskService, UserService)" as services
    rectangle "Walidacja i reguly biznesowe" as validation
}

rectangle "Warstwa dostepu do danych" as data_access #FFCCBC {
    rectangle "Repozytoria (TaskRepository, UserRepository)" as repos
    rectangle "ORM / mapowanie obiektowo-relacyjne" as orm
}

rectangle "Warstwa danych" as data #E1BEE7 {
    database "PostgreSQL" as db
}

rectangle "Warstwa bezpieczenstwa (przekrojowa)" as security #FFCDD2 {
    rectangle "Keycloak (OAuth2 / OpenID Connect)" as kc
    rectangle "JWT Token" as jwt
}

presentation -down-> api_layer
api_layer -down-> business
business -down-> data_access
data_access -down-> data

security -right-> presentation : ochrona tras
security -right-> business : autoryzacja

@enduml
