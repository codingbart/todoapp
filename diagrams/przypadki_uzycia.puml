@startuml
left to right direction
skinparam actorStyle awesome

actor "Użytkownik" as User
actor "Gość" as Guest
actor "Keycloak" as KC <<system>>

rectangle "System Todo App" {
    usecase "Zaloguj się" as UC1
    usecase "Zarejestruj się" as UC2
    usecase "Wyloguj się" as UC3
    usecase "Utwórz zadanie" as UC4
    usecase "Edytuj zadanie" as UC5
    usecase "Usuń zadanie" as UC6
    usecase "Wyświetl listę zadań" as UC7
    usecase "Filtruj zadania" as UC8
    usecase "Wyszukaj zadania" as UC9
    usecase "Wyświetl tablicę Kanban" as UC10
    usecase "Wyświetl dashboard" as UC11
    usecase "Wyświetl szczegóły zadania" as UC12
    usecase "Zmień status zadania" as UC13
    usecase "Ustaw priorytet zadania" as UC14
    usecase "Ustaw termin realizacji" as UC15
}

Guest --> UC1
Guest --> UC2

User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11
User --> UC12
User --> UC13

UC4 ..> UC14 : <<include>>
UC4 ..> UC15 : <<include>>
UC5 ..> UC13 : <<include>>
UC5 ..> UC14 : <<include>>
UC5 ..> UC15 : <<include>>

UC1 --> KC
UC2 --> KC

@enduml
