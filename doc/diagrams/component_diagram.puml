@startuml
skinparam componentStyle rectangle

package "Frontend (React 19 SPA)" {
    [App] as app
    [Router\n(react-router v7)] as router
    [Redux Store\n(Redux Toolkit)] as store

    package "Strony" {
        [TasksPage] as tasks
    }

    package "Komponenty UI" {
        [Layout] as layout
        [TaskDialog] as dialog
        [TaskItem] as item
        [StatCard] as stat
        [ProfileMenu] as profile
    }

    package "Stan aplikacji" {
        [tasksSlice] as slice
        [tasksThunks\n(fetch/create/delete)] as thunks
        [tasksSelectors] as selectors
    }

    package "Komponenty bazowe (shadcn/ui)" {
        [Button] as btn
        [Input] as input
        [Dialog] as dlg
        [Tooltip] as tooltip
    }
}

package "Backend (Go REST API)" {
    [Router (chi)] as chi
    [AuthMiddleware\n(JWT + Keycloak JWKS)] as authmw
    [TaskHandler] as taskCtrl
    [HealthHandler] as healthCtrl
    [TaskService] as taskSvc
    [HealthService] as healthSvc
    [Queries (sqlc)] as repo
    [Swagger UI] as swagger
}

package "Systemy zewnętrzne" {
    database "PostgreSQL\n(tasks, users)" as db
    [Keycloak\n(realm: todoapp)] as kc
    database "PostgreSQL\n(Keycloak)" as kcdb
}

app --> router
app --> store
router --> tasks
tasks --> dialog
tasks --> item
tasks --> stat
layout --> profile
slice <.. thunks
selectors ..> slice
tasks --> selectors
tasks --> thunks

chi --> authmw
authmw --> kc : weryfikacja JWT (JWKS)
authmw --> repo : sync użytkownika
chi --> taskCtrl
chi --> healthCtrl
chi --> swagger
taskCtrl --> taskSvc
healthCtrl --> healthSvc
taskSvc --> repo
healthSvc --> repo
repo --> db

kc --> kcdb

thunks ..> chi : REST API\n(/api/users/{id}/tasks,\n/api/users/{id}/dashboard)
profile ..> kc : login / logout

@enduml
